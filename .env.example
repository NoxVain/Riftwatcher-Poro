# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Riot Developer Portal API key. Use a personal or production key for real deployments.
RIOT_API_KEY=

# Postgres connection string, for example from Railway/Render/Fly.
DATABASE_URL=

# Discord channel IDs. Enable Developer Mode in Discord, then copy channel IDs.
DAILY_REPORT_CHANNEL_ID=
WEEKLY_REPORT_CHANNEL_ID=
MATCH_RECAP_CHANNEL_ID=
EVENTS_CHANNEL_ID=

# Local reporting window.
REPORT_TIMEZONE=UTC
REPORT_DAY_START_HOUR=6

# Riot routing. Use a platform route for league/summoner APIs and a regional route for account/match-v5 APIs.
RIOT_PLATFORM_ROUTING=euw1
RIOT_REGIONAL_ROUTING=europe

# Worker cadence and cache controls.
REPORT_CACHE_SECONDS=120
DAILY_REFRESH_SECONDS=300
MATCH_RECAP_POLL_SECONDS=90
MAX_TODAY_MATCH_DETAILS=100
MAX_MATCH_IDS_SCAN=2000
MAX_IN_MEMORY_MATCH_CACHE=200
MATCH_CACHE_RETENTION_DAYS=730
DB_POOL_SIZE=5

# Logging.
LOG_RIOT_REQUESTS=false
LOG_JSON=false
